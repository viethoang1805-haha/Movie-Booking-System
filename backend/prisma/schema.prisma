generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id        BigInt   @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  bookings  Booking[]
  reviews   Review[]

  @@index([email])
}

model Movie {
  id           BigInt   @id @default(autoincrement())
  title        String
  description  String?  @db.Text
  duration     Int
  releaseDate  DateTime
  posterUrl    String?

  showtimes    Showtime[]
  reviews      Review[]
}

model Theater {
  id        BigInt  @id @default(autoincrement())
  name      String
  location  String

  rooms     Room[]
}

model Room {
  id        BigInt  @id @default(autoincrement())
  name      String

  theaterId BigInt
  theater   Theater @relation(fields: [theaterId], references: [id])

  seats     Seat[]
  showtimes Showtime[]

  @@index([theaterId])
}

model Seat {
  id          BigInt @id @default(autoincrement())
  seatNumber  String

  roomId      BigInt
  room        Room   @relation(fields: [roomId], references: [id])

  bookingSeats BookingSeat[]

  @@unique([roomId, seatNumber])
  @@index([roomId])
}

model Showtime {
  id        BigInt   @id @default(autoincrement())
  startTime DateTime
  price     Float

  movieId   BigInt
  roomId    BigInt

  movie     Movie @relation(fields: [movieId], references: [id])
  room      Room  @relation(fields: [roomId], references: [id])

  bookings  Booking[]

  @@index([movieId])
  @@index([roomId])
}

model Booking {
  id          BigInt @id @default(autoincrement())
  totalPrice  Float
  status      BookingStatus @default(PENDING)
  createdAt   DateTime @default(now())

  userId      BigInt
  showtimeId  BigInt

  user        User     @relation(fields: [userId], references: [id])
  showtime    Showtime @relation(fields: [showtimeId], references: [id])

  seats       BookingSeat[]
  payment     Payment?

  @@index([userId])
  @@index([showtimeId])
}

model BookingSeat {
  id         BigInt @id @default(autoincrement())

  bookingId  BigInt
  seatId     BigInt

  booking    Booking @relation(fields: [bookingId], references: [id])
  seat       Seat    @relation(fields: [seatId], references: [id])

  @@unique([bookingId, seatId])
  @@index([bookingId])
  @@index([seatId])
}

model Payment {
  id         BigInt @id @default(autoincrement())
  amount     Float
  status     PaymentStatus @default(PENDING)
  method     String

  bookingId  BigInt @unique
  booking    Booking @relation(fields: [bookingId], references: [id])
}

model Review {
  id        BigInt @id @default(autoincrement())
  rating    Int
  comment   String? @db.Text
  createdAt DateTime @default(now())

  userId    BigInt
  movieId   BigInt

  user      User  @relation(fields: [userId], references: [id])
  movie     Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model Promotion {
  id              BigInt @id @default(autoincrement())
  code            String @unique
  discountPercent Int
  startDate       DateTime
  endDate         DateTime
}